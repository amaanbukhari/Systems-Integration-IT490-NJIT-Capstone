# THIS IS MUSIC / hosts.env

# RabbitMQ Hosts
RMQ_HOST=100.114.37.13
RMQ2_HOST=100.65.228.57
RMQ3_HOST=100.94.40.126

# DB Hosts
DB_HOST=100.78.226.13
DB2_HOST=100.64.56.116
DB3_HOST=100.124.122.18

# BE-FE Hosts
BE_FE_HOST=100.109.59.101
BE_FE2_HOST=100.123.219.59
# BE-DB Hosts
BE_DB_HOST=100.109.139.113
BE_DB2_HOST=100.95.250.77

# Frontend Hosts
FE_HOST=100.68.226.123
FE2_HOST=100.103.55.53

# SSH KEY
SSH_KEY=~/.ssh/thisismusic_ed25519

# Per-host SSH users
RMQ_SSH_USER=daniel
RMQ2_SSH_USER=daniel
RMQ3_SSH_USER=daniel
DB_SSH_USER=musicdb
DB2_SSH_USER=musicdb
DB3_SSH_USER=musicdb
BE_FE_SSH_USER=music
BE_FE2_SSH_USER=music
BE_DB_SSH_USER=music
BE_DB2_SSH_USER=music
FE_SSH_USER=meek
FE2_SSH_USER=meek

# RabbitMQ service
RMQ_SERVICE_START="sudo -n systemctl start rabbitmq-server"
RMQ_SERVICE_STOP="sudo -n systemctl stop rabbitmq-server"
RMQ_SERVICE_STATUS="systemctl is-active rabbitmq-server >/dev/null 2>&1 && echo UP || echo DOWN"
# MySQL service
MYSQL_SERVICE_START="sudo -n systemctl start mysql"
MYSQL_SERVICE_STOP="sudo -n systemctl stop mysql"
MYSQL_SERVICE_STATUS="systemctl is-active mysql >/dev/null 2>&1 && echo UP || echo DOWN"

# MySQL Router
ROUTER_BOOTSTRAP="sudo pkill -f mysqlrouter || true; sleep 2; for HOST in 100.78.226.13 100.64.56.116 100.124.122.18; do echo root123 | sudo mysqlrouter --bootstrap root@\$HOST:3306 --directory /tmp/myrouter --user=root --force && sudo chmod 777 /tmp/myrouter && break; done"
ROUTER2_BOOTSTRAP="sudo pkill -f mysqlrouter || true; sleep 2; for HOST in 100.78.226.13 100.64.56.116 100.124.122.18; do echo root123 | sudo mysqlrouter --bootstrap root@\$HOST:3306 --directory /tmp/myrouter --user=root --report-host 100.64.56.116 --force && sudo chmod 777 /tmp/myrouter && break; done"
ROUTER3_BOOTSTRAP="sudo pkill -f mysqlrouter || true; sleep 2; for HOST in 100.78.226.13 100.64.56.116 100.124.122.18; do echo root123 | sudo mysqlrouter --bootstrap root@\$HOST:3306 --directory /tmp/myrouter --user=root --report-host 100.124.122.18 --force && sudo chmod 777 /tmp/myrouter && break; done"
ROUTER_START="nohup sudo mysqlrouter --config /tmp/myrouter/mysqlrouter.conf > /tmp/myrouter/router.log 2>&1 & disown"
ROUTER_STOP="sudo pkill -f mysqlrouter || true"
ROUTER_STATUS="ss -lntp | grep 6446 >/dev/null 2>&1 && echo UP || echo DOWN"

# Frontend app
FE_START="nohup ~/thisismusic/frontend/venv/bin/python3 ~/thisismusic/frontend/app.py > ~/thisismusic/frontend/frontend.log 2>&1 &"
FE_STOP="pkill -f 'app.py' || true"
FE_STATUS="curl -s http://localhost:7012/health >/dev/null 2>&1 && echo UP || echo DOWN"

# Nginx
NGINX_START="sudo systemctl start nginx"
NGINX_STOP="sudo systemctl stop nginx"
NGINX_STATUS="systemctl is-active nginx >/dev/null 2>&1 && echo UP || echo DOWN"

# BE-FE worker
BE_FE_START="nohup /usr/bin/python3 ~/thisismusic/backend/be_fe.py > ~/thisismusic/backend/befe_worker.log 2>&1 &"
BE_FE_STOP="pkill -f 'be_fe.py' || true"
BE_FE_STATUS="ps aux | grep 'be_fe.py' | grep -v grep | grep -q . && echo UP || echo DOWN"

# DB worker
DB_WORKER_START="nohup ~/IT490/database/venv/bin/python3 ~/IT490/database/db_worker.py > ~/IT490/database/db_worker.log 2>&1 &"
DB2_WORKER_START="nohup ~/musicdb/IT490/database/venv/bin/python3 ~/musicdb/IT490/database/db_worker.py > ~/musicdb/IT490/database/db_worker.log 2>&1 &"
DB3_WORKER_START="nohup ~/IT490/database/venv/bin/python3 ~/IT490/database/db_worker.py > ~/IT490/database/db_worker.log 2>&1 &"
DB_WORKER_STOP="pkill -f 'db_worker.py' || true"
DB_WORKER_STATUS="ps aux | grep 'db_worker.py' | grep -v grep | grep -q . && echo UP || echo DOWN"
# BE-DB worker
BE_DB_START="nohup python3 ~/music/thisismusic/backend/be_db.py > ~/music/thisismusic/backend/bedb_worker.log 2>&1 &"
BE_DB_STOP="pkill -f 'be_db.py' || true"
BE_DB_STATUS="ps aux | grep 'be_db.py' | grep -v grep | grep -q . && echo UP || echo DOWN"

# Log file paths
FE_LOG="~/thisismusic/frontend/frontend.log"
FE2_LOG="~/thisismusic/frontend/frontend.log"
BE_FE_LOG="~/thisismusic/backend/befe_worker.log"
BE_FE2_LOG="~/thisismusic/backend/befe_worker.log"
BE_DB_LOG="~/music/thisismusic/backend/bedb_worker.log"
BE_DB2_LOG="~/music/thisismusic/backend/bedb_worker.log"
DB_WORKER_LOG="~/IT490/database/db_worker.log"
DB2_WORKER_LOG="~/musicdb/IT490/database/db_worker.log"
DB3_WORKER_LOG="~/IT490/database/db_worker.log"
